# Copier vers .env.ai-orchestrator (ignoré par Git) ou exporter dans le shell.
# Ne jamais committer les valeurs réelles.

# --- Fichier de règles (routage, coût de référence, logs) — pas de secrets ---
# AI_ORCHESTRATOR_CONFIG=/chemin/absolu/vers/ai_orchestrator.config.json

# --- LM Studio (API OpenAI-compatible locale) ---
# LM_STUDIO_BASE_URL=http://127.0.0.1:1234
# LM_STUDIO_API_KEY=
# LM_STUDIO_MODEL_LOW=gemma-4
# LM_STUDIO_MODEL_DEFAULT=gemma-4
# LM_STUDIO_TIMEOUT_MS=30000
# LM_STUDIO_HTTP_MODELS_TIMEOUT_SEC=30

# --- Cloud (clés uniquement via environnement / secrets injectés) ---
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# CLAUDE_MODEL=claude-3-5-haiku-20241022

# --- Optionnel : surcharge du tarif de référence (USD / million de tokens) ---
# CLOUD_COST_REFERENCE_GEMINI_FLASH_USD_PER_MILLION_TOKENS=0.075

# --- Comportement orchestrateur ---
# AI_ORCHESTRATOR_DEBUG=0
# AI_ORCHESTRATOR_DEFAULT_MAX_COST_USD=
